# Outlook provider:
# - desktop: local Outlook profile via COM/MAPI, best for this MVP
# - graph: Microsoft Graph, useful later for server-side automation
OUTLOOK_PROVIDER=desktop

# Desktop Outlook mailbox name. This should match the Outlook store display name.
# Example from your screenshot:
# OUTLOOK_MAILBOX_NAME=r.rabayev@korzinka.uz
OUTLOOK_MAILBOX_NAME=

# Graph authentication mode:
# - device_code: quick interactive local sign-in
# - client_credentials: unattended service-to-service auth
OUTLOOK_AUTH_MODE=device_code

# Azure app registration for the graph provider
OUTLOOK_TENANT_ID=your-tenant-id
OUTLOOK_CLIENT_ID=your-client-id
OUTLOOK_CLIENT_SECRET=your-client-secret
OUTLOOK_USER_ID=

# Mail folder can be a well-known name such as inbox, sentitems, drafts.
OUTLOOK_MAIL_FOLDER=inbox
OUTLOOK_ALL_FOLDERS=false

# Sync behavior
OUTLOOK_MAX_MESSAGES=25
OUTLOOK_SAVE_ATTACHMENTS=true
OUTLOOK_OUTPUT_DIR=raw/mail
OUTLOOK_HISTORICAL_UNREAD_CATCHUP_ENABLED=true
OUTLOOK_HISTORICAL_UNREAD_CATCHUP_BATCH_SIZE=100

# MVP storage and routing
AUTOMATION_DB_PATH=data/automation.db
AUTOMATION_READ_MODEL_PATH=data/mail_triage_read_model.json
MAIL_INTERNAL_DOMAINS=example.com
