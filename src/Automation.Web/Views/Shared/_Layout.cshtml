<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Crimson Automation</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Automation.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <div class="app-backdrop"></div>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand brand-lockup" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark"></span>
                    <span>
                        <strong>Crimson Automation</strong>
                        <small>Business Process Control</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="Home" asp-action="NeedsDecision">Needs Decision</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="Home" asp-action="Privacy">Data Policy</a>
                        </li>
                    </ul>
                    <div class="header-status">
                        <span class="status-dot"></span>
                        <span>Outlook, API, Fabric, SLA</span>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2026 Crimson Automation</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Data and access policy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
